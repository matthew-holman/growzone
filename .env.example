# PostgreSQL — matches the docker-compose defaults
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
POSTGRES_DB=grow_calendar_postgres
POSTGRES_PORT=5432

# Connection string for Drizzle (used in drizzle.config.ts and your Hono app)
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/grow_calendar_postgres

# Nominatim usage policy requires a real contact address in the User-Agent header
NOMINATIM_CONTACT=your@email.com
